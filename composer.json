{
    "name": "brunoggdev/ci4-logging-extended",
    "description": "Extended logging for CodeIgniter 4: improved context serialization, exception() method with rich context, web-based Log Viewer with IDE deep links, and exception alerting.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Gomes",
            "email": "brunoggdev@gmail.com"
        }
    ],
    "require": {},
    "require-dev": {
        "codeigniter4/framework": "^4.3",
        "codeigniter4/devkit": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Brunoggdev\\LoggingExtended\\": "src/"
        },
        "files": [
            "src/Helpers/logger_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Brunoggdev\\LoggingExtended\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix --ansi --verbose --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
